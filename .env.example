TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash
ALLOWED_USERS=

SPREADSHEET_ID=

# Coolify'da en pratik yöntem: service account JSON içeriğini tek secret olarak verin.
GOOGLE_SHEETS_CREDENTIALS_JSON=

# Alternatif: JSON dosyasını volume/secret olarak mount edip yolunu verin.
GOOGLE_SHEETS_CREDENTIALS_PATH=/app/credentials.json

# Container içinde fiş Markdown dosyalarının yazılacağı klasör.
DATA_DIR=/app/data

# Coolify public HTTP arayüz portu.
PORT=3000
